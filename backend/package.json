{
  "name": "zcoffee-backend",
  "version": "1.0.0",
  "description": "Z Coffee POS - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "predev": "ts-node prisma/setup.ts",
    "build": "tsc",
    "prebuild": "ts-node prisma/setup.ts",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "preprisma:generate": "ts-node prisma/setup.ts",
    "prisma:migrate": "prisma migrate dev",
    "preprisma:migrate": "ts-node prisma/setup.ts",
    "prisma:push": "prisma db push",
    "preprisma:push": "ts-node prisma/setup.ts",
    "prisma:seed": "ts-node prisma/seed.ts",
    "preprisma:seed": "ts-node prisma/setup.ts",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.25",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
